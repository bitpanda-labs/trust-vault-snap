{
  "version": "0.1.5",
  "description": "An account management snap that interacts with Bitpanda Custody subwallets to sign transactions",
  "proposedName": "TrustVault",
  "repository": {
    "type": "git",
    "url": "git+git@github.com:bitpanda-labs/trust-vault-snap.git"
  },
  "source": {
    "shasum": "6RTfmbztqoctcMqsTQk4S4/C4bVx5XnZFjm0Rb9hNo0=",
    "location": {
      "npm": {
        "filePath": "dist/bundle.js",
        "iconPath": "resources/trustvault.svg",
        "packageName": "@bitpandacustody/trust-vault-snap",
        "registry": "https://registry.npmjs.org/"
      }
    }
  },
  "initialPermissions": {
    "endowment:keyring": {
      "allowedOrigins": [
        "http://localhost:8083"
      ]
    },
    "snap_dialog": {},
    "endowment:network-access": {},
    "snap_manageAccounts": {},
    "snap_manageState": {},
    "snap_getEntropy": {},
    "endowment:rpc": {
      "allowedOrigins": [
        "http://localhost:8083"
      ]
    },
    "endowment:cronjob": {
      "jobs": [
        {
          "expression": "* * * * *",
          "request": {
            "method": "checkPendingRequests"
          }
        }
      ]
    }
  },
  "manifestVersion": "0.1"
}
